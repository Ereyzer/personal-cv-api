{
  "name": "personal-cv-api",
  "version": "1.0.0",
  "description": "API for my CV ",
  "main": "dist/index.js",
  "type": "module",
  "source": "app/index.ts",
  "types": "dist/index.d.ts",
  "scripts": {
    "test": "jest",
    "lint": "eslint --cache --fix --color",
    "develop-mode-in-container": "nodemon",
    "innit": "./scripts/init-script.sh",
    "container:build": "docker compose -f compose.yaml up --build -d",
    "container:watch-api-app": "./scripts/start-watch.sh",
    "container:start-mongo": "docker compose up db-mongo -d",
    "container:start-api": "docker compose up api-app -d",
    "container:start": "docker compose -f compose.prod.yaml up --build",
    "container:stop": "docker compose stop",
    "container:stop-mongo": "docker compose stop db-mongo",
    "mongodb:CLI": "docker exec -it db-mongo mongosh",
    "innitdb": "bash ./scripts/db-innit.sh .env",
    "mongosh:connect": "mongosh mongodb://localhost:27017/cvdata",
    "prepare": "husky install",
    "dev": "nodemon",
    "clean": "rm -rf dist",
    "serve": "nodemon dist/index.js",
    "build": "npm run clean && parcel build --no-cache",
    "watch": "parcel watch",
    "dep-test": "npm run build",
    "container:build-deploy": "docker compose -f compose.prod.yaml up --build",
    "start": "node ./dist/index.js"
  },
  "keywords": [],
  "author": "Ivan Laver <ereyzer142@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ereyzer/personal-cv-api.git"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@jest/globals": "^29.7.0",
    "@parcel/packager-ts": "^2.15.1",
    "@parcel/transformer-css-experimental": "^2.3.2",
    "@parcel/transformer-typescript-tsc": "^2.15.1",
    "@parcel/transformer-typescript-types": "^2.15.1",
    "@swc/core": "^1.11.9",
    "@swc/helpers": "^0.5.15",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.9",
    "@types/swagger-ui-dist": "^3.30.5",
    "@types/swagger-ui-express": "^4.1.7",
    "assert": "^2.1.0",
    "browserify-zlib": "^0.2.0",
    "crypto-browserify": "^3.12.1",
    "dotenv": "^16.4.7",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.3",
    "events": "^3.3.0",
    "globals": "^15.13.0",
    "husky": "^8.0.0",
    "jest": "^29.7.0",
    "lint-staged": "^15.4.3",
    "mongodb": "^6.14.2",
    "mongosh": "^2.3.9",
    "nodemon": "^3.1.9",
    "os-browserify": "^0.3.0",
    "parcel": "^2.15.1",
    "path-browserify": "^1.0.1",
    "prettier": "^3.5.3",
    "process": "^0.11.10",
    "querystring-es3": "^0.2.1",
    "regenerator-runtime": "^0.14.1",
    "stream-browserify": "^3.0.0",
    "stream-http": "^3.2.0",
    "ts-jest": "^29.2.5",
    "tsconfig-paths": "^4.2.0",
    "tslib": "^2.8.1",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.18.0",
    "url": "^0.11.4",
    "util": "^0.12.5",
    "vm-browserify": "^1.1.2"
  },
  "dependencies": {
    "express": "^4.21.2",
    "joi": "^17.13.3",
    "mongoose": "^8.9.5",
    "multer": "^1.4.5-lts.1",
    "swagger-ui-dist": "^5.21.0",
    "swagger-ui-express": "^5.0.1"
  }
}
