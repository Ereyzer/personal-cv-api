{
  "name": "personal-cv-api",
  "version": "1.0.0",
  "description": "API for my CV ",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "test": "jest",
    "lint": "eslint --cache --fix --color",
    "develop-mode-in-container": "nodemon",
    "innit": "./scripts/init-script.sh",
    "container:build": "docker compose -f compose.yaml up --build -d",
    "container:watch-api-app": "./scripts/start-watch.sh",
    "container:start-mongo": "docker compose up db-mongo -d",
    "container:start-api": "docker compose up api-app -d",
    "container:start": "docker compose -f compose.prod.yaml up --build",
    "container:stop": "docker compose stop",
    "container:stop-mongo": "docker compose stop db-mongo",
    "mongodb:CLI": "docker exec -it db-mongo mongosh",
    "innitdb": "bash ./scripts/db-innit.sh .env",
    "mongosh:connect": "mongosh mongodb://localhost:27017/cvdata",
    "prepare": "husky install",
    "dev": "nodemon --exec tsx watch src/index.ts --tsconfig tsconfig.dev.json",
    "start": "node src/index.js",
    "build": "tsc --project tsconfig.prod.json",
    "vercel-build": "echo Hello"
  },
  "keywords": [],
  "author": "Ivan Laver <ereyzer142@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ereyzer/personal-cv-api.git"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@jest/globals": "^29.7.0",
    "@swc/core": "^1.11.9",
    "@swc/helpers": "^0.5.15",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.9",
    "@types/swagger-ui-express": "^4.1.7",
    "dotenv": "^16.4.7",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.3",
    "globals": "^15.13.0",
    "husky": "^8.0.0",
    "jest": "^29.7.0",
    "lint-staged": "^15.4.3",
    "mongodb": "^6.14.2",
    "mongosh": "^2.3.9",
    "nodemon": "^3.1.9",
    "prettier": "^3.5.3",
    "regenerator-runtime": "^0.14.1",
    "ts-jest": "^29.2.5",
    "tsconfig-paths": "^4.2.0",
    "tslib": "^2.8.1",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.18.0"
  },
  "dependencies": {
    "express": "^4.21.2",
    "joi": "^17.13.3",
    "mongoose": "^8.9.5",
    "multer": "^1.4.5-lts.1",
    "swagger-ui-express": "^5.0.1"
  }
}
